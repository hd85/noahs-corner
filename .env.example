# Copy this file to ".env" and fill in the values.
# The .env file is git-ignored so your secrets are never committed.

# --- Question generation (server-side secret) ---
# Your private Anthropic API key. Lives only on the server (Vercel), never in
# the browser. This one is a SECRET — keep it safe.
ANTHROPIC_API_KEY=your_key_here

# --- Cross-device sync (safe to be public) ---
# From your Supabase project's API settings. These are designed to live in the
# browser; the database's row-level security is what keeps data private.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
